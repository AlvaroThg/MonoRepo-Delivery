# ─── Satélite Delivery — Variables de entorno ────────────────────────────────
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas .env a git.

# URL base de tu API Laravel levantada por docker compose
API_BASE_URL=http://localhost:8080/api

# Timeout de peticiones en milisegundos
API_TIMEOUT=10000
